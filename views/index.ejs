</body>
<script>

    const menuBtn = document.getElementById('menu-btn');
    const closeBtn = document.getElementById('close-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    // Fungsi Buka Menu
    menuBtn.addEventListener('click', () => {
        mobileMenu.classList.remove('translate-x-full');
    });

    // Fungsi Tutup Menu
    const closeMenu = () => {
        mobileMenu.classList.add('translate-x-full');
    };

    closeBtn.addEventListener('click', closeMenu);

    // Otomatis tutup menu kalau link diklik
    mobileLinks.forEach(link => {
        link.addEventListener('click', closeMenu);
    });
    // Inisialisasi AOS
  AOS.init({
    duration: 1000, // Durasi animasi (1 detik)
    once: true,     // Animasi hanya jalan sekali saat di-scroll
    offset: 100     // Jarak scroll sebelum animasi mulai (pixel)
  });
  function switchTab(type) {
        const tabWeb = document.getElementById('tab-website');
        const tabSistem = document.getElementById('tab-sistem');
        const btnWeb = document.getElementById('btn-website');
        const btnSistem = document.getElementById('btn-sistem');

        if (type === 'website') {
            // Tampilan Grid
            tabWeb.classList.remove('hidden');
            setTimeout(() => { tabWeb.classList.add('opacity-100', 'scale-100'); tabWeb.classList.remove('opacity-0', 'scale-95'); }, 10);
            tabSistem.classList.add('hidden', 'opacity-0', 'scale-95');
            
            // Tampilan Tombol
            btnWeb.classList.add('bg-blue-600', 'text-white', 'shadow-lg');
            btnWeb.classList.remove('text-slate-600');
            btnSistem.classList.remove('bg-blue-600', 'text-white', 'shadow-lg');
            btnSistem.classList.add('text-slate-600');
        } else {
            // Tampilan Grid
            tabSistem.classList.remove('hidden');
            setTimeout(() => { tabSistem.classList.add('opacity-100', 'scale-100'); tabSistem.classList.remove('opacity-0', 'scale-95'); }, 10);
            tabWeb.classList.add('hidden', 'opacity-0', 'scale-95');

            // Tampilan Tombol
            btnSistem.classList.add('bg-blue-600', 'text-white', 'shadow-lg');
            btnSistem.classList.remove('text-slate-600');
            btnWeb.classList.remove('bg-blue-600', 'text-white', 'shadow-lg');
            btnWeb.classList.add('text-slate-600');
        }
    }
</script>
