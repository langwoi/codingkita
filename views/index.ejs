        <div class="space-y-4">
            <details class="group p-6 rounded-3xl border border-slate-100 bg-slate-50 cursor-pointer transition-all hover:bg-white hover:shadow-xl hover:border-blue-100" data-aos="fade-up" data-aos-delay="100">
