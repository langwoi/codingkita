<section id="harga" class="py-24 bg-slate-50 px-6">
    <div class="container mx-auto">
        <div class="text-center mb-12" data-aos="fade-up">
            <h2 class="text-3xl md:text-5xl font-extrabold mb-4">Investasi Bisnis Terbaik</h2>
            <p class="text-slate-500 font-medium mb-10">Pilih kategori layanan yang sesuai dengan kebutuhan bisnismu.</p>

            <div class="inline-flex p-1.5 bg-slate-200/50 rounded-2xl backdrop-blur-sm mb-8">
                <button onclick="switchTab('website')" id="btn-website" class="tab-btn px-8 py-3 rounded-xl font-bold text-sm transition-all duration-300 bg-blue-600 text-white shadow-lg">
                    Website UMKM
                </button>
                <button onclick="switchTab('sistem')" id="btn-sistem" class="tab-btn px-8 py-3 rounded-xl font-bold text-sm transition-all duration-300 text-slate-600 hover:text-white-600">
                    Sistem Informasi
                </button>
            </div>

        <div id="tab-website" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto transition-all duration-500 opacity-100 scale-100">
            <% packages.filter(p => p.category === 'website').forEach(pkg => { %>
                <div class="relative bg-white p-8 md:p-10 rounded-[40px] border <%= pkg.recommended ? 'border-blue-500 shadow-2xl scale-105 z-10' : 'border-slate-200 shadow-sm' %> flex flex-col h-full group hover:shadow-xl transition-all duration-500">
                    <% if (pkg.recommended) { %>
                        <div class="absolute -top-5 left-1/2 -translate-x-1/2 bg-blue-600 text-white px-5 py-1.5 rounded-full text-[10px] font-bold tracking-widest uppercase">Paling Populer</div>
                    <% } %>
                    <span class="text-blue-600 font-bold text-xs tracking-widest uppercase mb-3 block"><%= pkg.name %></span>
                    <div class="flex items-baseline mb-8">
                        <span class="text-sm font-bold text-slate-900 mr-1">Rp</span>
                        <span class="text-4xl font-extrabold text-slate-900"><%= pkg.price %></span>
                    </div>
                    <ul class="space-y-4 mb-10 flex-grow">
                        <% pkg.features.forEach(feature => { %>
                            <li class="flex items-start text-slate-600 text-sm font-semibold">
                                <div class="w-5 h-5 bg-blue-50 rounded-full flex items-center justify-center mr-3 mt-0.5 shrink-0">
                                    <i class="fas fa-check text-[8px] text-blue-600"></i>
                                </div>
                                <%= feature %>
                            </li>
                        <% }) %>
                    </ul>
                    <a href="https://wa.me/6285236509562?text=Halo+CodingKita,+mau+tanya+<%= pkg.name %>" class="w-full py-4 rounded-2xl text-center font-bold transition-all duration-300 <%= pkg.recommended ? 'bg-blue-600 text-white' : 'bg-slate-900 text-white' %>">
                        Konsultasi Sekarang
                    </a>
                </div>
            <% }) %>
        </div>
          </div>

        <div id="tab-sistem" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto transition-all duration-500 opacity-0 scale-95">
            <% packages.filter(p => p.category === 'sistem').forEach(pkg => { %>
                <div class="relative bg-white p-8 md:p-10 rounded-[40px] border border-slate-200 shadow-sm flex flex-col h-full group hover:shadow-xl transition-all duration-500">
                    <span class="text-indigo-600 font-bold text-xs tracking-widest uppercase mb-3 block"><%= pkg.name %></span>
                    <div class="flex items-baseline mb-8">
                        <span class="text-sm font-bold text-slate-900 mr-1">Rp</span>
                        <span class="text-4xl font-extrabold text-slate-900"><%= pkg.price %></span>
                    </div>
                    <ul class="space-y-4 mb-10 flex-grow">
                        <% pkg.features.forEach(feature => { %>
                            <li class="flex items-start text-slate-600 text-sm font-semibold">
                                <div class="w-5 h-5 bg-indigo-50 rounded-full flex items-center justify-center mr-3 mt-0.5 shrink-0">
                                    <i class="fas fa-check text-[8px] text-indigo-600"></i>
                                </div>
                                <%= feature %>
                            </li>
                        <% }) %>
                    </ul>
                    <a href="https://wa.me/6285236509562" class="w-full py-4 rounded-2xl text-center font-bold bg-slate-900 text-white hover:bg-blue-600 transition-all">
                        Konsultasi Sekarang
                    </a>
                </div>
            <% }) %>
        </div>
    </div>
</section>